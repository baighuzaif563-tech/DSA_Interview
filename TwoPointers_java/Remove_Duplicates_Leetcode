class Solution {
    public int removeDuplicates(int[] nums) {

        int unique=1;
        int cm=1;
        int officer=0;


        while(cm<nums.length){
            if(nums[cm]!=nums[cm-1]){
                unique++;
                nums[officer+1]=nums[cm];
                officer++;
            }
            cm++;
        }

        return unique;
        
    }
}
