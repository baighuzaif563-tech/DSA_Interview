class Solution {
    int countTriplets(int sum, int arr[]) {
        
        Arrays.sort(arr);
    int n=arr.length;
    
  
    int ans=0;
   
    
    for(int i=0;i<n-2;i++){
        int left=i+1;
          int right=arr.length-1;
    
    while(left<right){
        int  sum1=arr[i]+arr[left]+arr[right];
    
    if(sum1>=sum){
        right--;
    }
     if(sum1<sum){
         ans=ans+right-left; // imp trick
         left++;  
     }
     
    }
    
    }
     
     return ans;
    }
}
