class Solution {
    public int maximumWealth(int[][] accounts) {
   
int max=0;

      for(int i=0;i<accounts.length;i++){
        int sum=0;
        int j=0;
        while(j<accounts[i].length){
     sum=sum+accounts[i][j];
      j++;
        }
        max=Math.max(sum,max);
      }

      return max;
    }
}
