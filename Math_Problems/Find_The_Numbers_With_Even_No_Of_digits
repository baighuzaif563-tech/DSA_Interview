class Solution {
    public int findNumbers(int[] nums) {
        int count=0;
        
        int n=nums.length;
        for(int i=0;i<n;i++){

            int countdigits=0;
            while(nums[i]!=0){
              countdigits++;
              nums[i]=nums[i]/10;
            }
            if(countdigits%2==0){
                count++;
            }
        }
        return count;
    }
}
