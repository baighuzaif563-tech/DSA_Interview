class Solution {
    static boolean isPrime(int n) {
        // code here
        boolean flag=true;
    if(n<2){
        return false;
    }
    else{
        for(int i=2;i*i<=n;i++){
            if(n%i==0){
                flag=false;
                break;
            }
        }
       
        return flag;
    }
    }
}
