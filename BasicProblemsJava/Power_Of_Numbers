class Solution {
    public int reverseExponentiation(int n) {
        // code here
        int a=reverse(n);
       return (int)Math.pow(n, a);
    
    }
   
    
    
    int reverse(int n){
       int rev=0;
     
        while(n!=0){
            rev=rev*10+n%10;
            n=n/10;
        }
        return rev;
    }
}
