class Solution {
    public boolean isBalanced(String num) {
        int i=0;
        int sum1=0;
        int sum2=0;
        while(i<num.length()){
        if(i%2==0){
            sum1=sum1+num.charAt(i)-'0';
            i++;
        }
        else{
            sum2=sum2+num.charAt(i)-'0';
            i++;
        }
        }
        if(sum1==sum2){
            return true;
        }
        return false;
    }
}
