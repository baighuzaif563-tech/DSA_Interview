class Solution {
    public int factorial(int n){
        if(n==0 || n==1){
            return 1;
        }
        return n* factorial(n-1);
    }
    public boolean isStrong(int n) {
        // code here
        int temp=n;
         int sum=0;
         while(n!=0){
             int digit=n%10;
             sum=sum+factorial(digit);
             n=n/10;
         }
         if(sum==temp){
             return true;
         }
         
         return false;
    }
}
