class Solution {
    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        List<List<Integer>>ans=new ArrayList<>();
        int index=0;
        ArrayList<Integer>diary=new ArrayList<>();
    sum(candidates,0,ans,diary,0,target);

        return ans;
    }
   
    public void sum(int [] candidates,int index,List<List<Integer>>ans,ArrayList<Integer>diary,int sum,int target){

        // Base Case

if(sum==target){
    ans.add(new ArrayList<>(diary));
    return;
}

if(index==candidates.length || sum>target){
    return;
}

   // pick

diary.add(candidates[index]);// kitne bhi Baar le skte h 

 // kitne bhi baar lene ke liye 
 sum(candidates,index,ans,diary,sum+candidates[index],target);
   // backtrack
diary.remove(diary.size()-1);


// agr nhi liya toh skip karjao

sum(candidates,index+1,ans,diary,sum,target);

   //skip 


    }



    
}

