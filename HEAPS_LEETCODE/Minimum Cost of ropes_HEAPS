Minimum Cost of ropesclass Solution {
    public static int minCost(int[] arr) {
        // code here
        int total=0;       
        PriorityQueue<Integer>pq=new PriorityQueue<>();
        for(int i=0;i<arr.length;i++){
            pq.add(arr[i]);
        }
        
        while(pq.size()>1){  // bs yha tha baki shi tha
            int first=pq.poll();
            int second=pq.poll();
            int sum=first+second;
            pq.add(sum);
            total=total+sum;
        }
        return total;
    }
}
