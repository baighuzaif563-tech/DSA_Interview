class Solution {
    int LowerBound(int[] arr, int target) {
        // code here
        // do hi cndition rhengi
        
        int guess=arr.length;
        int low =0;
        int high=arr.length-1;
        
        while(low<=high){
          int  mid = low + (high - low) / 2;
           
             if(arr[mid]<target){
                
                guess=mid;
                low=mid+1;
            }
            else{
                high=mid-1;
            }
        }
            
            
        
        return guess;
    }
}
