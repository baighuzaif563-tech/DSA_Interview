class Solution {

    Boolean ans=false;
    public boolean hasPathSum(TreeNode root, int targetSum) {
        

       sum(root,0,targetSum);
       return ans;
    
    }


    public boolean sum(TreeNode root,int sum,int target){
        if(root==null){
            return false;
        }


        if(root!=null){
            sum=sum+root.val;
        }

        if(root.left==null && root.right==null){
            if(sum==target){
                ans=true;
            }
        }

        sum(root.left,sum,target);
    sum(root.right,sum,target);

    return ans;
    }
    
}
