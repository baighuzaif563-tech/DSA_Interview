// Min Depth of the Tree

int MinDepth(int root){
if(root==null){
return 0;
}

if(root.left==null && root.right==null){
return 1;
}
if(root.left==null){
return 1+height(root.right);
}


if(root.right==null){
return 1+height(root.left);
}

return 1+Math.max(left,right);

