class Solution {
    public ArrayList<Integer> getMinMax(int[] arr) {
        // code Here
        ArrayList<Integer>ans=new ArrayList<>();
        int min=Integer.MAX_VALUE;
        int max=0;
        for(int i=0;i<arr.length;i++){
           
            min=Math.min(min,arr[i]);
        }
        
        ans.add(min);
       
       
       for(int i=0;i<arr.length;i++){
           max=Math.max(max,arr[i]);
       }
       ans.add(max);
       
       return ans;
        
    }
}
