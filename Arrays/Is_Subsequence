class Solution {
    public boolean isSubsequence(String s, String t) {
     Stack<Character>st=new Stack<>();
     int index=0;
     for(int i=0;i<t.length();i++){
        if (index == s.length()) {
                break;
            }

        if(s.charAt(index)!=t.charAt(i)){
            continue;
        }

        else{
        st.push(t.charAt(i));
        index++;

        }
     }
return st.size()==s.length();
    }
}
