5. Find Numbers with Even Number of Digits

class Solution {
    public int findNumbers(int[] nums) {
       int count=0;
        
        for(int i=0;i<nums.length;i++){
            int num=nums[i];
           int count1=0;
            while(num!=0){

              
                count1++;
                 
                num=num/10;
            }
            if(count1%2==0){
                count++;
            }
            else{
                continue;
            }
        }
        return count;
    }
}
