class Solution {
    public int[] getConcatenation(int[] nums) {
        int n=nums.length;
        int[]ans=new int[nums.length*2];
        int j=0;
int i=0;
        while(i<nums.length){
            ans[j++]=nums[i++];
            
        }
        if(i==n){
            i=0;
            while(i<nums.length){
                ans[j++]=nums[i++];
            }
        }
        return ans;
    }
}
