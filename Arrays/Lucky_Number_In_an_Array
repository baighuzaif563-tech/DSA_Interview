class Solution {
    public int findLucky(int[] arr) {
        HashMap<Integer,Integer>map=new HashMap<>();
int ans=-1;
        for(int x:arr){
            map.put(x,map.getOrDefault(x,0)+1);
        }

  for(int x:arr){
    if(map.get(x)==x){
        ans=Math.max(x,ans);
    }
  }
        
        return ans;
    }
}
