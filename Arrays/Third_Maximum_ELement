
import java.util.*;

class Solution {
    public int thirdMax(int[] nums) {

        TreeSet<Integer> set = new TreeSet<>();

        for(int x : nums){
            set.add(x);
        }

        if(set.size() < 3){
            return set.last();
        }

        set.pollLast();   // remove 1st maximum
        set.pollLast();   // remove 2nd maximum

        return set.last(); // 3rd maximum
    }
}
