class Solution {
    public static boolean checkEqual(int[] a, int[] b) {
        // code here
      HashMap<Integer,Integer>map1=new HashMap<>();
      
      HashMap<Integer,Integer>map2=new HashMap<>();
      for(int x:a){
          map1.put(x,map1.getOrDefault(x,0)+1);
      }
      
       for(int x:b){
          map2.put(x,map2.getOrDefault(x,0)+1);
      }
      if(map1.equals(map2)){
          return true;
      }
      return false;
    }
}
