class Solution {
    public int findMinDiff(int arr[], int m) {
        // code here
        Arrays.sort(arr);
       int low=0;
       int high=m-1;
       int max=Integer.MIN_VALUE;
       int min=Integer.MAX_VALUE;
       int diff=Integer.MAX_VALUE;
       int i=0;
       while(high<arr.length){
           
        
          diff=Math.min(diff,arr[high]-arr[low]);
          low++;
          high++;
          
       }
       
        return diff;
        
    }
}
